# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow_dev
DATABASE_URL_TEST=postgresql://taskflow_test:test_password@localhost:5432/taskflow_test

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Web Push (generar con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
VAPID_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
VAPID_EMAIL=mailto:admin@taskflow.app
